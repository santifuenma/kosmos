# ─────────────────────────────────────────────────────────────────────────────
# .env.example — plantilla de variables de entorno para Kosmos.
#
# Copia este fichero como `.env` y rellena cada variable con un valor real.
# El fichero `.env` está en .gitignore: nunca lo subas al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos ───────────────────────────────────────────────────────────
# SQLite local. Prisma 7 lee la ruta real desde prisma.config.ts, así que
# este valor en .env es redundante en desarrollo; se mantiene por compatibilidad
# con herramientas que esperan DATABASE_URL en el entorno.
DATABASE_URL="file:./dev.db"

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Clave usada para firmar los JWT de sesión. Genera una nueva con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Nunca uses la misma clave en producción que en desarrollo y nunca la subas a git.
NEXTAUTH_SECRET=

# URL pública desde la que se accede a la aplicación. En desarrollo local suele
# ser http://localhost:3000; si quieres probar desde otro dispositivo en la LAN,
# usa la IP de tu máquina, por ejemplo http://192.168.1.30:3000.
NEXTAUTH_URL=http://localhost:3000
